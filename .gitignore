# 1. Block EVERYTHING in the root directory
/*

# 2. ALLOW the PWA folder and its contents
!/land-converter-pwa/

# 3. ALLOW essential Git and GitHub configuration
!/.gitignore
!/.github/
!/README.md

# 4. Handle PWA specific ignores (standard Node/Vite)
# These are usually handled by land-converter-pwa/.gitignore as well
land-converter-pwa/node_modules/
land-converter-pwa/dist/
land-converter-pwa/.env*

# 5. OS and Editor files (global ignore)
.DS_Store
Thumbs.db
.vscode/
.idea/
